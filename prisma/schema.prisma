generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Tenants (Shops) ──────────────────────────────────────────────────────────
//
// A Shop is a single barber shop tenant. Every business entity (users, barbers,
// services, clients, appointments) belongs to exactly one shop, providing strict
// data isolation between tenants. SUPER_ADMIN users have shopId = null and can
// see/manage all shops; everyone else is scoped to their shop.
//
// slug: shop URL-safe identifier (future: tenant routing)
// status: SUSPENDED shops cannot accept new bookings or admin logins

model Shop {
  id              String     @id @default(cuid())
  slug            String     @unique
  customDomain    String?    @unique // e.g. "mehmetberber.com" — set by super admin after DNS is wired
  name            String
  logo            String?
  coverImage      String? // hero banner for public landing
  address         String?    @db.Text
  addressLine     String? // street line; pairs with city for structured display
  city            String?
  latitude          Float?
  longitude         Float?
  formattedAddress  String?
  locationUpdatedAt DateTime?
  phone           String?
  whatsappNumber  String? // E.164 — opens wa.me on landing
  email           String?
  description     String?    @db.Text
  about           String?    @db.Text // long-form "Hakkımızda" copy, max 500 chars
  ownerName       String?
  foundedYear     Int?
  shopType        String? // "male" | "female" | "unisex"
  // ponytail: separate columns for socials so we can validate URLs per-field at
  // write time. Existing `social` JSON kept for backward compat; new admin UI
  // writes both for now, public page reads the new columns first.
  instagramUrl    String?
  facebookUrl     String?
  tiktokUrl       String?
  website         String?
  gallery         String[]   @default([]) // ordered Cloudinary URLs, max 12
  featuredImage   String? // pinned hero: one gallery URL or coverImage; null = auto
  mobileSettings  Json? // { coverStyle, barberDisplay, serviceDisplay, sectionVisibility }
  social          Json? // legacy { instagram, facebook, tiktok, twitter, website }
  googlePlaceId   String? // per-shop Google Place ID for reviews widget
  googlePlacesKey String? // per-shop Google Places API key (overrides global env)
  googleReviewUrl String? // direct Google review link shown after 4★+ internal reviews
  mapsEmbed       String?    @db.Text // custom Google Maps embed URL
  status          ShopStatus @default(ACTIVE)
  timezone        String     @default("Europe/Istanbul")
  currency        String     @default("TRY")

  // Default commission % for new barbers. Each barber can override on their
  // own record; this is the fallback when admin adds one without specifying.
  defaultCommissionRate Int @default(50)

  // When true (default) public POST /api/appointments creates CONFIRMED rows
  // and matches the "Anında Onay" landing copy. Set false to require admin
  // approval — bookings land as PENDING and stay there until status PATCH.
  autoConfirmBookings Boolean @default(true)

  // ─── Subscription / billing ────────────────────────────────────────────────
  // Single source of truth for plan limits + access. Billing helpers in
  // lib/subscription.js read these fields; plan limits in lib/plans.js key off
  // planTier. paymentProviderRef holds the iyzico/stripe customer or sub id.
  planTier            PlanTier           @default(STARTER)
  subscriptionStatus  SubscriptionStatus @default(TRIAL)
  trialEndsAt         DateTime?
  currentPeriodEndsAt DateTime?
  paymentProvider     String? // "iyzico" | "stripe" — null until wired
  paymentProviderRef  String? // provider-side customer / subscription id

  // ponytail: soft delete. Hard delete is blocked by Invoice/AuditLog FK Restrict.
  // resolveShopBySlug filters deletedAt = null. Restore by setting back to null.
  deletedAt DateTime?

  // Aggregate cache — recomputed in the same tx that inserts a Review row.
  // Reading these on the public tenant page is O(1) vs scanning every Review.
  avgRating    Float @default(0)
  totalReviews Int   @default(0)

  // Google Places cache — written by getGoogleReviews() when a shop detail page is visited.
  googleRating       Float?
  googleTotalRatings Int?

  // ─── Amenities ────────────────────────────────────────────────────────────
  wifi            Boolean @default(false)
  parking         Boolean @default(false)
  creditCard      Boolean @default(false)
  airConditioning Boolean @default(false)
  disabledAccess  Boolean @default(false)
  childFriendly   Boolean @default(false)
  hasPromotions   Boolean @default(false)

  // Per-shop toggle for the 2h post-completion review reminder cron.
  reviewReminderEnabled Boolean @default(true)

  // Birthday campaign — per-salon, opt-in only. Disabled by default.
  // type: null | "FREE_HAIRCUT" | "PERCENTAGE" | "FIXED" | "FREE_SERVICE" | "COUPON"
  birthdayCampaignType   String?  // null = disabled
  birthdayCampaignValue  Float?   // discount % or fixed amount
  birthdayCampaignCoupon String?  // custom coupon code for COUPON type

  users                User[]
  barbers              Barber[]
  services             Service[]
  clients              Client[]
  appointments         Appointment[]
  holidays             Holiday[]
  auditLogs            AuditLog[]
  notifications        Notification[]
  notificationSettings NotificationSettings?
  notificationJobs     NotificationJob[]
  reviewRequests       ReviewRequest[]
  reviews              Review[]
  invoices             Invoice[]
  analyticsEvents      AnalyticsEvent[]
  favoritedBy          CustomerFavorite[]
  shopMetrics          ShopMetric[]
  loyaltyPoints        LoyaltyPoint[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, deletedAt])         // base filter on every public list query
  @@index([status, deletedAt, avgRating])  // rating sort (most common)
  @@index([status, deletedAt, totalReviews]) // mostReviewed sort
  @@index([status, deletedAt, createdAt])  // newest sort
  @@index([city])                      // city filter
}

// Lightweight conversion-funnel telemetry. Public ingest, never blocks UX.
// ponytail: single table, no aggregation. Add a daily rollup table if event
// volume crosses ~100k/day per shop.
model AnalyticsEvent {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  eventType String // see lib/analytics.js EVENT_TYPES allowlist
  metadata  Json? // tiny payload — serviceId, barberId, source, etc.
  createdAt DateTime @default(now())

  @@index([shopId, createdAt])
  @@index([shopId, eventType, createdAt])
}

enum ShopStatus {
  ACTIVE
  SUSPENDED
}

enum PlanTier {
  STARTER
  PRO
  ENTERPRISE
}

// Subscription lifecycle. SUSPENDED blocks public booking but admin/staff
// panels remain accessible (see lib/subscription.js).
enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

// ─── Invoices ─────────────────────────────────────────────────────────────────
// Append-only ledger of payment events. The provider webhook handler inserts
// rows; we never UPDATE except on refunds.
model Invoice {
  id                String    @id @default(cuid())
  shopId            String
  shop              Shop      @relation(fields: [shopId], references: [id], onDelete: Restrict)
  providerInvoiceId String?   @unique // iyzico/stripe ref — null for manual entries
  provider          String? // "iyzico" | "stripe" | "manual"
  amount            Int // minor units (kuruş for TRY)
  currency          String    @default("TRY")
  status            String // "paid" | "failed" | "pending" | "refunded"
  paidAt            DateTime?
  paymentMethod     String? // "card" | "transfer" | "manual"
  periodStart       DateTime?
  periodEnd         DateTime?
  raw               Json? // provider payload for audit
  createdAt         DateTime  @default(now())

  @@index([shopId, createdAt])
  @@index([status])
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String?  @unique // login identifier shown in UI
  displayName  String? // optional display name override
  passwordHash String
  role         Role     @default(BARBER)
  tokenVersion Int      @default(0) // increment on logout to invalidate all tokens
  shopId       String? // null for SUPER_ADMIN; required for everyone else (enforced in app)
  shop         Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  barberId     String?  @unique
  barber       Barber?  @relation(fields: [barberId], references: [id])
  clientId     String?  @unique // set when role = CUSTOMER
  client       Client?  @relation(fields: [clientId], references: [id])

  // Customer profile fields (role = CUSTOMER only)
  phone     String?
  birthday  DateTime?
  gender    String? // "male" | "female" | "other"
  avatarUrl String?

  // Notification preferences
  notifAppt     Boolean @default(true)
  notifReminder Boolean @default(true)
  notifPromo    Boolean @default(false)

  pushTokens       PushToken[]
  favorites        CustomerFavorite[]
  barberFavorites  BarberFavorite[]
  loyaltyPoints    LoyaltyPoint[]
  reviews          Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  BARBER
  RECEPTIONIST
  CUSTOMER
}

// ─── Barbers ──────────────────────────────────────────────────────────────────

model Barber {
  id           String   @id @default(cuid())
  shopId       String
  shop         Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  slug         String
  nameTr       String
  nameEn       String
  titleTr      String
  titleEn      String
  bioTr        String   @db.Text
  bioEn        String   @db.Text
  avatar       String
  profilePhoto String? // base64 data URL or external URL
  color        String   @default("#CC1A1A")
  rating       Float    @default(5.0)
  reviewCount  Int      @default(0)
  yearsExp     Int      @default(1)
  available    Boolean  @default(true)
  specialties  String[]

  // Earnings model. PERCENTAGE → commissionRate is the cut (e.g. 60 = barber
  // keeps 60% of finalPrice). FIXED → barber paid fixedSalary regardless; the
  // shop keeps 100% of appointment gross. Defaults match the shop's
  // defaultCommissionRate at insert time (handled in /api/admin/barbers).
  paymentType    PaymentType @default(PERCENTAGE)
  commissionRate Int         @default(50)
  fixedSalary    Int?

  user           User?
  appointments   Appointment[]
  workingHours   WorkingHours?
  breaks         BarberBreak[]
  holidays       Holiday[]
  services       BarberService[]
  reviewRequests ReviewRequest[]
  reviews        Review[]
  favoritedBy    BarberFavorite[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([shopId, slug])
  @@index([shopId])
}

// Working hours: values stored as minutes from midnight (540 = 09:00, 570 = 09:30)
model WorkingHours {
  id       String @id @default(cuid())
  barberId String @unique
  barber   Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)
  monStart Int?
  monEnd   Int?
  tueStart Int?
  tueEnd   Int?
  wedStart Int?
  wedEnd   Int?
  thuStart Int?
  thuEnd   Int?
  friStart Int?
  friEnd   Int?
  satStart Int?
  satEnd   Int?
  sunStart Int?
  sunEnd   Int?
}

model BarberBreak {
  id        String  @id @default(cuid())
  barberId  String
  barber    Barber  @relation(fields: [barberId], references: [id], onDelete: Cascade)
  start     String // "HH:MM"
  end       String // "HH:MM"
  label     String  @default("Mola")
  dayOfWeek Int? // 0=Sun … 6=Sat, null = recurring every day
  date      String? // "YYYY-MM-DD" — set for one-off breaks (e.g. instant "Mola"). null = recurring.

  @@index([barberId])
  @@index([date])
}

// ─── Services ─────────────────────────────────────────────────────────────────

model Service {
  id           String          @id @default(cuid())
  shopId       String
  shop         Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  nameTr       String
  nameEn       String
  descTr       String
  descEn       String
  duration     Int
  price        Int? // null = "Sorulur" — barber doesn't have to publish a fixed price
  icon         String          @default("✂️")
  image        String?
  category     ServiceCategory
  popular      Boolean         @default(false)
  active       Boolean         @default(true)
  sortOrder    Int             @default(0)
  appointments Appointment[]
  barbers      BarberService[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([shopId])
}

enum ServiceCategory {
  CUTS
  BEARD
  COMBO
  PREMIUM
}

// Barber ↔ Service many-to-many (which services a barber can perform)
model BarberService {
  barberId  String
  serviceId String
  barber    Barber  @relation(fields: [barberId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([barberId, serviceId])
}

// ─── Clients ──────────────────────────────────────────────────────────────────

model Client {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name        String
  phone       String
  email       String?
  notes       String?  @db.Text
  photos      String[] // URLs or storage keys for client reference photos
  noShowCount Int      @default(0)
  blocked     Boolean  @default(false)

  // Lifetime metrics — updated on appointment completion in a transaction.
  // Cheap to read; recomputing from Appointment scans is O(n) per client.
  totalSpent    Int            @default(0)
  visitCount    Int            @default(0)
  lastVisitAt   DateTime?
  appointments  Appointment[]
  notifications Notification[]
  reviews       Review[]
  user          User? // set if client has a CUSTOMER account
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([shopId, phone])
  @@index([shopId, name])
}

// ─── Appointments ─────────────────────────────────────────────────────────────

model Appointment {
  id        String            @id @default(cuid())
  shopId    String
  shop      Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client            @relation(fields: [clientId], references: [id])
  barberId  String
  barber    Barber            @relation(fields: [barberId], references: [id])
  serviceId String
  service   Service           @relation(fields: [serviceId], references: [id])
  date      String // "YYYY-MM-DD"
  time      String // "HH:MM"
  duration  Int
  price     Int? // null = "Sorulur" — final price set on completion
  status    AppointmentStatus @default(PENDING)
  source    BookingSource     @default(ONLINE)
  notes     String?           @db.Text

  // Revenue + completion bookkeeping. grossAmount is the final charged price
  // (set on COMPLETED transition). barberAmount/shopAmount are pre-split per
  // the barber's paymentType + commissionRate; both must equal grossAmount.
  // tipAmount is on top, paid 100% to the barber (never split).
  grossAmount   Int?
  barberAmount  Int?
  shopAmount    Int?
  tipAmount     Int            @default(0)
  paymentMethod PaymentMethod?
  completedAt   DateTime?

  // Cancellation audit — who cancelled and why. Reason is free text for now;
  // promote to enum once we see real patterns. cancelledBy: "client" | "shop"
  // | "barber" — distinct from the human's user id (kept simple).
  cancelledAt        DateTime?
  cancellationReason String?   @db.Text
  cancelledBy        String?

  // Walk-in marker — set true via the dedicated POST path (Phase 3) when a
  // barber/admin captures a customer who showed up without booking online.
  // customServiceName lets walk-ins skip the service catalog ("Sakal düzeltme").
  isWalkIn          Boolean @default(false)
  customServiceName String?

  // Set true the moment a customer submits a Review. Belt-and-suspenders
  // against double-submission; the unique constraint on Review.appointmentId
  // is the actual guard.
  reviewed Boolean @default(false)

  // Customer-uploaded reference photos (Cloudinary URLs). Barber sees them on the day.
  photoUrls String[] @default([])

  // QR check-in token — generated on booking, scanned on arrival.
  checkInToken  String?  @unique @default(cuid())
  checkedInAt   DateTime?

  // Who made the booking (may differ from the client if booking for someone else)
  bookedByUserId String?
  bookedByName   String?

  notifications    Notification[]
  auditLogs        AuditLog[]
  notificationJobs NotificationJob[]
  reviewRequest    ReviewRequest?
  review           Review?
  loyaltyPoint     LoyaltyPoint?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([barberId, date, time]) // race condition guard
  @@index([shopId, date])
  @@index([shopId, status])
  @@index([barberId, date])
  @@index([clientId])
  @@index([date])
  @@index([date, status]) // revenue reports
  @@index([status])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NOSHOW
}

enum BookingSource {
  ONLINE
  WALK_IN
  MANUAL
}

enum PaymentType {
  PERCENTAGE
  FIXED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

// ─── Holidays ─────────────────────────────────────────────────────────────────

model Holiday {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  barberId  String? // null = shop-wide (all barbers)
  barber    Barber?  @relation(fields: [barberId], references: [id], onDelete: Cascade)
  date      String // "YYYY-MM-DD"
  label     String   @default("Tatil")
  createdAt DateTime @default(now())

  @@index([shopId, date])
  @@index([date])
  @@index([barberId, date])
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id            String       @id @default(cuid())
  shopId        String? // null for platform-level actions by SUPER_ADMIN
  shop          Shop?        @relation(fields: [shopId], references: [id], onDelete: Restrict)
  entity        String // "appointment", "barber", etc.
  entityId      String
  action        String // "status_change", "reschedule", "delete", "create"
  before        Json?
  after         Json?
  userId        String? // who performed the action (null = system / public)
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())

  @@index([shopId, createdAt])
  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

// ─── Precomputed daily metrics ────────────────────────────────────────────────
// Populated nightly by /api/cron/shop-metrics. Avoids 10+ live aggregations on
// every stats page load. The cron writes one row per (shopId, date), upserted
// so re-runs are idempotent and missed nights can be backfilled.

model ShopMetric {
  id               String @id @default(cuid())
  shopId           String
  shop             Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  date             String // YYYY-MM-DD (shop local date)
  revenue          Float  @default(0) // sum(grossAmount ?? price) for COMPLETED
  shopAmount       Float  @default(0) // sum(shopAmount) for COMPLETED
  barberAmount     Float  @default(0) // sum(barberAmount) for COMPLETED
  appointmentCount Int    @default(0) // non-cancelled
  completedCount   Int    @default(0)
  cancelledCount   Int    @default(0)
  walkInCount      Int    @default(0)
  newClientCount   Int    @default(0)

  @@unique([shopId, date])
  @@index([shopId, date])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id            String       @id @default(cuid())
  shopId        String
  shop          Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  clientId      String?
  client        Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  type          String // "reminder", "confirmation", "cancellation", "reschedule"
  channel       String // "sms", "email", "push"
  body          String?      @db.Text
  sentAt        DateTime?
  status        String       @default("pending") // "pending", "sent", "failed"
  createdAt     DateTime     @default(now())

  @@index([shopId, status])
  @@index([clientId])
  @@index([appointmentId])
  @@index([status])
}

model NotificationSettings {
  id     String @id @default(cuid())
  shopId String @unique
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  smsEnabled Boolean @default(false)
  waEnabled  Boolean @default(false)

  netgsmUser     String?
  netgsmPassword String?
  netgsmHeader   String? // SMS sender name (max 11 chars)

  reminder48h     Boolean @default(true)
  reminder3h      Boolean @default(true)
  followupEnabled Boolean @default(false)
  followupHours   Int     @default(24)

  tplCreated     String? @db.Text
  tplConfirmed   String? @db.Text
  tplCancelled   String? @db.Text
  tplReminder48h String? @db.Text
  tplReminder3h  String? @db.Text
  tplFollowup    String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotificationJob {
  id            String         @id @default(cuid())
  shopId        String
  shop          Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  appointmentId String?
  appointment   Appointment?   @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  channel       NotifChannel
  event         NotifEvent
  // Nullable: IN_APP/PUSH channels don't need a phone number. SMS/WHATSAPP
  // still require it — enforced in lib that enqueues the job, not the schema.
  phone         String?
  message       String         @db.Text
  scheduledFor  DateTime
  status        NotifJobStatus @default(PENDING)
  attempts      Int            @default(0)
  maxAttempts   Int            @default(3)
  lastError     String?        @db.Text
  processedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status, scheduledFor])
  @@index([shopId, createdAt])
  @@index([appointmentId])
}

enum NotifChannel {
  SMS
  WHATSAPP
  // ponytail: IN_APP + PUSH reserved for the future mobile app — no delivery
  // handler yet. Enqueue freely; a worker will pick them up when it exists.
  IN_APP
  PUSH
}

enum NotifEvent {
  CREATED
  CONFIRMED
  CANCELLED
  REMINDER_48H
  REMINDER_3H
  FOLLOWUP
}

enum NotifJobStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  CANCELLED
}

// ─── Review Requests ──────────────────────────────────────────────────────────
// Created when an appointment reaches COMPLETED status.
// After 2 hours, a cron job sends an SMS with a unique review link.

model ReviewRequest {
  id            String              @id @default(cuid())
  shopId        String
  shop          Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  appointmentId String              @unique
  appointment   Appointment         @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  barberId      String
  barber        Barber              @relation(fields: [barberId], references: [id], onDelete: Cascade)
  token         String              @unique @default(cuid())
  customerName  String
  customerPhone String
  customerEmail String?
  status        ReviewRequestStatus @default(PENDING)
  sentAt        DateTime?
  reviewedAt    DateTime?
  rating        Int? // 1-5
  comment       String?             @db.Text
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([shopId, status])
  @@index([barberId])
  @@index([status, createdAt])
}

enum ReviewRequestStatus {
  PENDING // not yet sent
  SENT // SMS sent, awaiting review
  REVIEWED // customer submitted rating
  SKIPPED // could not send (no phone, etc.)
}

// ─── Reviews (internal) ──────────────────────────────────────────────────────
// Customer-submitted ratings for one appointment. Separate from ReviewRequest
// (which tracks SMS/WA dispatch lifecycle) so the content lives in one place
// and the dispatch tracker stays a pure state machine.
//
// One Review per Appointment (unique). Insert is gated on:
//   appointment.status === COMPLETED && appointment.reviewed === false.
// Shop and Barber aggregates are recomputed in the same transaction.
model Review {
  id            String      @id @default(cuid())
  shopId        String
  shop          Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  barberId      String
  barber        Barber      @relation(fields: [barberId], references: [id], onDelete: Cascade)
  customerId    String? // null for walk-ins or pre-account submissions
  customer      Client?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  userId        String?     // set when submitted by an authenticated CUSTOMER User account
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  shopRating    Int // 1-5; salon as a whole
  barberRating  Int // 1-5; the assigned barber
  comment       String?     @db.Text
  createdAt     DateTime    @default(now())

  @@index([shopId, createdAt])
  @@index([barberId, createdAt])
  @@index([shopId, shopRating])
  @@index([barberId, barberRating])
}

// ─── Platform Leads ───────────────────────────────────────────────────────────
// Prospective customers who fill out the contact form on the SaaS landing page.

model Lead {
  id           String   @id @default(cuid())
  businessName String
  name         String
  phone        String
  email        String?
  message      String?  @db.Text
  createdAt    DateTime @default(now())
}

// ─── Webhook Idempotency ──────────────────────────────────────────────────────
// One row per (provider, eventId). Insert on entry; PK conflict = replay → ack.
model ProcessedWebhookEvent {
  provider    String
  eventId     String
  processedAt DateTime @default(now())

  @@id([provider, eventId])
  @@index([processedAt])
}

// ─── Push Tokens ──────────────────────────────────────────────────────────────
// One row per (user, token). Upserted on app launch after permission grant.
// TODO: add FCM/APNS delivery worker when push provider is chosen.
model PushToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String // "ios" | "android" | "web"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ─── Customer Favorites ───────────────────────────────────────────────────────
// Backend-synced favorites for CUSTOMER accounts. Guest favorites remain in
// AsyncStorage (useFavoritesStore) and are merged on login.
model CustomerFavorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, shopId])
  @@index([userId])
}

// ─── Barber Favorites ─────────────────────────────────────────────────────────
model BarberFavorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  barberId  String
  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, barberId])
  @@index([userId])
}

// ─── Loyalty Points ───────────────────────────────────────────────────────────
// Simple event-sourced ledger. Balance = SUM(points) per (userId, shopId).
// Negative points represent redemptions.
model LoyaltyPoint {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopId        String
  shop          Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  appointmentId String?     @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  points        Int         // positive = earn, negative = redeem
  reason        String      // "appointment" | "review" | "referral" | "redemption"
  createdAt     DateTime    @default(now())

  @@index([userId, shopId])
  @@index([shopId])
}
