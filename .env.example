# ── Database (Neon / PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=""

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Google Places ─────────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=""
GOOGLE_PLACE_ID=""
# Optional: used to redirect 5-star reviewers to Google Maps
GOOGLE_REVIEW_URL=""

# ── Notifications (Twilio / WhatsApp / SMS) ──────────────────────────────────
# Add your provider credentials here — never commit real values
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER=""

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Optional. When unset, reset links are logged to the console (dev-friendly).
RESEND_API_KEY=""
EMAIL_FROM="Makas <noreply@makas.app>"

# ── Rate limiting (Upstash Redis) ─────────────────────────────────────────────
# Optional. When both are set, rate limits are distributed via Upstash.
# Leave empty in dev — falls back to an in-process bucket per Node instance.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Cron ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
CRON_SECRET=""

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Super Admin (used by prisma/create-superadmin.js only) ───────────────────
SUPERADMIN_EMAIL=""
SUPERADMIN_PASSWORD=""
