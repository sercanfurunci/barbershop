# ─────────────────────────────────────────────────────────────────────────────
# MAKAS — Environment Variables
# Copy to .env.local for local development.
# Never commit real values. Production secrets live in Vercel environment settings.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Neon / PostgreSQL) ──────────────────────────────────────────────
# Pooled connection for Prisma queries (pgBouncer compatible)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true"
# Direct connection for migrations (bypasses pgBouncer)
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
# REQUIRED in production — server throws on startup if missing
JWT_SECRET=""

# ── Cloudinary (image storage + CDN) ─────────────────────────────────────────
# Public cloud name (used in browser for signed upload widgets)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
# Server-side keys (never exposed to client)
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Full URL format — used by some routes directly
# CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"

# ── SMS / WhatsApp Notifications (Netgsm) ─────────────────────────────────────
# REQUIRED in production for appointment notifications
NETGSM_USER=""
NETGSM_PASSWORD=""
# Header shown as sender name on SMS messages (max 11 chars, alphanumeric)
NETGSM_HEADER="MAKAS"

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Optional. When unset, password-reset links are logged to console (dev-friendly).
RESEND_API_KEY=""
EMAIL_FROM="Makas <noreply@makas.app>"

# ── Google Maps / Places ──────────────────────────────────────────────────────
# Server-side: geocoding + Places API (shop route, barber profiles)
GOOGLE_PLACES_API_KEY=""
# Client-side: Leaflet/Maps embeds on public shop pages
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# ── Rate Limiting (Upstash Redis) ─────────────────────────────────────────────
# Optional. When both are set, rate limits are distributed across Vercel instances.
# Leave empty in dev — falls back to in-process bucket (single instance only).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Cron Jobs ─────────────────────────────────────────────────────────────────
# Shared secret for Vercel Cron → /api/cron/* routes.
# Generate with: openssl rand -hex 32
# Set this in Vercel dashboard AND in vercel.json cron Authorization header.
CRON_SECRET=""

# ── App / Platform ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Default timezone for date calculations (shop timezone overrides per-tenant)
NEXT_PUBLIC_DEFAULT_TZ="Europe/Istanbul"

# ── Super Admin ───────────────────────────────────────────────────────────────
# IP allowlist for /superadmin/* routes (comma-separated, e.g. "1.2.3.4,5.6.7.8")
# Leave empty to allow from all IPs (acceptable if hidden behind VPN/firewall)
SUPER_ADMIN_IP_ALLOWLIST=""
# Used by prisma/create-superadmin.js seed script only
SUPERADMIN_EMAIL=""
SUPERADMIN_PASSWORD=""

# ── Demo Tenant ───────────────────────────────────────────────────────────────
# Credentials for the /demo auto-login route (sales demos)
DEMO_EMAIL="demo-admin@makas.tech"
DEMO_PASSWORD="demo123"

# ── Payment Providers (architecture stubs — not yet active) ──────────────────
# iyzico (Turkey)
IYZICO_API_KEY=""
IYZICO_SECRET_KEY=""
# Stripe (international)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── AI Providers (architecture stubs — not yet active) ────────────────────────
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""
