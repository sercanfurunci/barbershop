# ── Database (Neon / PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=""

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Google Places ─────────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=""
GOOGLE_PLACE_ID=""
# Optional: used to redirect 5-star reviewers to Google Maps
GOOGLE_REVIEW_URL=""

# ── Notifications (Twilio / WhatsApp / SMS) ──────────────────────────────────
# Add your provider credentials here — never commit real values
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER=""

# ── Cron ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
CRON_SECRET=""

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Super Admin (used by prisma/create-superadmin.js only) ───────────────────
SUPERADMIN_EMAIL=""
SUPERADMIN_PASSWORD=""
